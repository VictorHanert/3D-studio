# =============================================================================
# Production Environment Variables Template
# Copy to Azure App Service → Configuration → Application Settings
# =============================================================================

# --- Application ---
APP_NAME=PlannerStudio
APP_ENV=production
APP_KEY=                            # Generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://planner-studio.azurewebsites.net  # Sweden Central

# --- Logging (stderr for Azure Log Analytics) ---
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Database (Azure MySQL Flexible Server) ---
DB_CONNECTION=mysql
DB_HOST=planner-studio-mysql.mysql.database.azure.com  # Sweden Central
DB_PORT=3306
DB_DATABASE=planner_studio
DB_USERNAME=planner
DB_PASSWORD=                        # Set in Azure App Settings (hidden)
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# --- Cache ---
CACHE_STORE=database

# --- Queue ---
QUEUE_CONNECTION=database

# --- Storage ---
FILESYSTEM_DISK=local

# --- Mail (configure when needed) ---
MAIL_MAILER=log

# --- Security ---
BCRYPT_ROUNDS=12
